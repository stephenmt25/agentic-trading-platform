# Agentic Trading Platform - Configuration Example
# Prefix all application settings with AION_

# -----------------
# 1. Infrastructre
# -----------------
# Redis connection URL (e.g. redis://user:pass@host:port/db)
AION_REDIS_URL=redis://localhost:6379/0

# Redis password for Docker Compose requirepass authentication.
# Must match the REDIS_PASSWORD used in deploy/docker-compose.yml.
REDIS_PASSWORD=changeme_redis_dev

# TimescaleDB connection string
AION_DATABASE_URL=postgresql://user:password@localhost:5432/aion_trading

# -----------------
# 2. General Config
# -----------------
# Master trading toggle (must be explicitly enabled for execution)
AION_TRADING_ENABLED=false

# Paper trading mode forces execution to testnets only
AION_PAPER_TRADING_MODE=false

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
AION_LOG_LEVEL=INFO

# -----------------
# 3. Validation and Safety Constraints
# -----------------
# Network/Evaluation timeout for fast-gate validation
AION_FAST_GATE_TIMEOUT_MS=50

# Portfolio-wide circuit breaker (e.g., stopping all trades if PNL hits this loss)
AION_CIRCUIT_BREAKER_DAILY_LOSS_PCT=0.02

# Retention configuration 
AION_HOT_DATA_RETENTION_DAYS=7

# Sentiment caching duration
AION_SENTIMENT_CACHE_TTL_S=900

# -----------------
# 4. Exchange & External Dependencies
# -----------------
# Force Binance API calls to the testnet
AION_BINANCE_TESTNET=true

# Force Coinbase API calls to sandbox
AION_COINBASE_SANDBOX=true

# -----------------
# 5. External API Keys
# -----------------
# NEVER COMMIT SECRETS
AION_LLM_API_KEY=""
AION_NEWS_API_KEY=""
AION_PAGERDUTY_API_KEY=""
AION_GCS_BUCKET_NAME=""
# (Add specific Exchange keys through GCP Secret Manager in production)
