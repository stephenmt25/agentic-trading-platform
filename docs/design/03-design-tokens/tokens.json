{
  "$schema": "https://design-tokens.org/draft/format/",
  "$description": "Praxis trading platform — design tokens. DTCG-format. Consumed by Style Dictionary, Tailwind config generation, and direct CSS variable export. Mode-scoped for HOT/COOL/CALM (see 01-design-philosophy.md).",
  "$version": "1.0.0-draft",

  "color": {
    "$description": "Color tokens are organized by SEMANTIC role, not by hue. Six chromatic roles: bid, ask, neutral, accent, warn, danger. A seventh group (agent) exists as named tokens for component code clarity but per ADR-012 all six agent identities alias to color.accent.500 — agents differentiate by glyph, label, and column position. Anything outside this taxonomy is rejected.",

    "neutral": {
      "$description": "Grayscale ramp. Used for chrome, structure, non-directional data. Background base is a true charcoal (#0b0b0d, not pure black) to prevent OLED smear.",
      "0":   { "$value": "#ffffff", "$type": "color" },
      "50":  { "$value": "#f7f7f8", "$type": "color" },
      "100": { "$value": "#ededef", "$type": "color" },
      "200": { "$value": "#d4d4d8", "$type": "color" },
      "300": { "$value": "#a1a1aa", "$type": "color" },
      "400": { "$value": "#71717a", "$type": "color" },
      "500": { "$value": "#52525b", "$type": "color" },
      "600": { "$value": "#3f3f46", "$type": "color" },
      "700": { "$value": "#27272a", "$type": "color" },
      "800": { "$value": "#18181b", "$type": "color" },
      "900": { "$value": "#0f0f12", "$type": "color" },
      "950": { "$value": "#0b0b0d", "$type": "color" },
      "1000":{ "$value": "#000000", "$type": "color" }
    },

    "bid": {
      "$description": "Bid-side / positive-PnL / own-buys. Slightly desaturated emerald — Hyperliquid-adjacent but lower saturation to coexist with neutrals without screaming. Avoid pure #00ff00.",
      "50":  { "$value": "#ecfdf5", "$type": "color" },
      "100": { "$value": "#d1fae5", "$type": "color" },
      "200": { "$value": "#a7f3d0", "$type": "color" },
      "300": { "$value": "#6ee7b7", "$type": "color" },
      "400": { "$value": "#34d399", "$type": "color" },
      "500": { "$value": "#10b981", "$type": "color" },
      "600": { "$value": "#059669", "$type": "color" },
      "700": { "$value": "#047857", "$type": "color" },
      "800": { "$value": "#065f46", "$type": "color" },
      "900": { "$value": "#064e3b", "$type": "color" },
      "tick-flash": { "$value": "rgba(16, 185, 129, 0.18)", "$type": "color", "$description": "Background flash when a bid-side price ticks up. 180ms decay." }
    },

    "ask": {
      "$description": "Ask-side / negative-PnL / own-sells. Distinct from `danger` — semantically about direction of money, not severity. Slightly orange-tinted red so it's not confused with kill-switch red.",
      "50":  { "$value": "#fef2f2", "$type": "color" },
      "100": { "$value": "#fee2e2", "$type": "color" },
      "200": { "$value": "#fecaca", "$type": "color" },
      "300": { "$value": "#fca5a5", "$type": "color" },
      "400": { "$value": "#f87171", "$type": "color" },
      "500": { "$value": "#ef4444", "$type": "color" },
      "600": { "$value": "#dc2626", "$type": "color" },
      "700": { "$value": "#b91c1c", "$type": "color" },
      "800": { "$value": "#991b1b", "$type": "color" },
      "900": { "$value": "#7f1d1d", "$type": "color" },
      "tick-flash": { "$value": "rgba(239, 68, 68, 0.18)", "$type": "color" }
    },

    "accent": {
      "$description": "The single brand-voice hue. Used for interactive affordances, focus rings, the platform's 'voice.' Indigo-violet — cooler than typical fintech blue, more considered than crypto purple. Used SPARINGLY.",
      "50":  { "$value": "#eef2ff", "$type": "color" },
      "100": { "$value": "#e0e7ff", "$type": "color" },
      "200": { "$value": "#c7d2fe", "$type": "color" },
      "300": { "$value": "#a5b4fc", "$type": "color" },
      "400": { "$value": "#818cf8", "$type": "color" },
      "500": { "$value": "#6366f1", "$type": "color" },
      "600": { "$value": "#4f46e5", "$type": "color" },
      "700": { "$value": "#4338ca", "$type": "color" },
      "800": { "$value": "#3730a3", "$type": "color" },
      "900": { "$value": "#312e81", "$type": "color" }
    },

    "warn": {
      "$description": "Soft thresholds, advisory. Amber. Distinct from danger — warn means 'pay attention,' danger means 'stop.'",
      "400": { "$value": "#fbbf24", "$type": "color" },
      "500": { "$value": "#f59e0b", "$type": "color" },
      "600": { "$value": "#d97706", "$type": "color" },
      "700": { "$value": "#b45309", "$type": "color" }
    },

    "danger": {
      "$description": "Kill-switch territory. Hard violations. A truer, more saturated red than `ask` — it must not blend in with negative PnL.",
      "500": { "$value": "#dc2626", "$type": "color" },
      "600": { "$value": "#b91c1c", "$type": "color" },
      "700": { "$value": "#991b1b", "$type": "color" },
      "armed-bg": { "$value": "rgba(220, 38, 38, 0.06)", "$type": "color", "$description": "When kill switch is hard-armed, every surface gets this overlay." }
    },

    "agent": {
      "$description": "Per-agent identity tokens. Per ADR-012, all six agents alias to color.accent.500 — chromatic differentiation is rejected; agents differentiate by glyph + label + column position. The token names persist so component code reads as 'agent identity', but the rendered hue is uniformly indigo.",
      "ta": {        "$value": "{color.accent.500}", "$type": "color", "$description": "ta_agent — accent (differentiate by glyph)" },
      "regime": {    "$value": "{color.accent.500}", "$type": "color", "$description": "regime_hmm — accent (differentiate by glyph)" },
      "sentiment": { "$value": "{color.accent.500}", "$type": "color", "$description": "sentiment — accent (differentiate by glyph)" },
      "slm": {       "$value": "{color.accent.500}", "$type": "color", "$description": "slm_inference — accent (differentiate by glyph)" },
      "debate": {    "$value": "{color.accent.500}", "$type": "color", "$description": "debate — accent (differentiate by glyph)" },
      "analyst": {   "$value": "{color.accent.500}", "$type": "color", "$description": "analyst — accent (differentiate by glyph)" }
    }
  },

  "typography": {
    "$description": "Two faces, used at multiple scales and weights. IBM Plex Sans for prose and UI; IBM Plex Mono for tabular numerics, code, and IDs. See ADR-011.",

    "fontFamily": {
      "sans":     { "$value": "'IBM Plex Sans', ui-sans-serif, system-ui, -apple-system, sans-serif", "$type": "fontFamily" },
      "mono":     { "$value": "'IBM Plex Mono', ui-monospace, 'SF Mono', Menlo, monospace", "$type": "fontFamily" },
      "tabular":  { "$value": "'IBM Plex Mono', ui-monospace, 'SF Mono', Menlo, monospace", "$type": "fontFamily", "$description": "Tabular numerics use Plex Mono directly. Apply with font-feature-settings: 'tnum' 1." }
    },

    "fontWeight": {
      "regular":  { "$value": 400, "$type": "fontWeight" },
      "medium":   { "$value": 500, "$type": "fontWeight" },
      "semibold": { "$value": 600, "$type": "fontWeight" },
      "bold":     { "$value": 700, "$type": "fontWeight" }
    },

    "fontSize": {
      "$description": "Type scale based on a 4px grid. Prefer the named tokens (caption/body/etc) over raw sizes.",
      "10":   { "$value": "10px", "$type": "dimension" },
      "11":   { "$value": "11px", "$type": "dimension" },
      "12":   { "$value": "12px", "$type": "dimension" },
      "13":   { "$value": "13px", "$type": "dimension" },
      "14":   { "$value": "14px", "$type": "dimension" },
      "15":   { "$value": "15px", "$type": "dimension" },
      "16":   { "$value": "16px", "$type": "dimension" },
      "18":   { "$value": "18px", "$type": "dimension" },
      "20":   { "$value": "20px", "$type": "dimension" },
      "24":   { "$value": "24px", "$type": "dimension" },
      "30":   { "$value": "30px", "$type": "dimension" },
      "36":   { "$value": "36px", "$type": "dimension" },
      "48":   { "$value": "48px", "$type": "dimension" }
    },

    "scale": {
      "caption":     { "$value": { "fontFamily": "{typography.fontFamily.sans}", "fontSize": "{typography.fontSize.11}", "fontWeight": "{typography.fontWeight.medium}",  "lineHeight": "1.3", "letterSpacing": "0.02em" }, "$type": "typography" },
      "label":       { "$value": { "fontFamily": "{typography.fontFamily.sans}", "fontSize": "{typography.fontSize.12}", "fontWeight": "{typography.fontWeight.medium}",  "lineHeight": "1.4", "letterSpacing": "0.01em" }, "$type": "typography" },
      "body-dense":  { "$value": { "fontFamily": "{typography.fontFamily.tabular}", "fontSize": "{typography.fontSize.13}", "fontWeight": "{typography.fontWeight.regular}", "lineHeight": "1.45" }, "$type": "typography" },
      "body":        { "$value": { "fontFamily": "{typography.fontFamily.sans}", "fontSize": "{typography.fontSize.14}", "fontWeight": "{typography.fontWeight.regular}", "lineHeight": "1.5" }, "$type": "typography" },
      "body-large":  { "$value": { "fontFamily": "{typography.fontFamily.sans}", "fontSize": "{typography.fontSize.15}", "fontWeight": "{typography.fontWeight.regular}", "lineHeight": "1.55" }, "$type": "typography" },
      "subtitle":    { "$value": { "fontFamily": "{typography.fontFamily.sans}", "fontSize": "{typography.fontSize.16}", "fontWeight": "{typography.fontWeight.semibold}", "lineHeight": "1.4" }, "$type": "typography" },
      "title":       { "$value": { "fontFamily": "{typography.fontFamily.sans}", "fontSize": "{typography.fontSize.20}", "fontWeight": "{typography.fontWeight.semibold}", "lineHeight": "1.3" }, "$type": "typography" },
      "display-sm":  { "$value": { "fontFamily": "{typography.fontFamily.tabular}", "fontSize": "{typography.fontSize.24}", "fontWeight": "{typography.fontWeight.semibold}", "lineHeight": "1.2", "letterSpacing": "-0.01em" }, "$type": "typography", "$description": "Used for primary numeric readouts: PnL ticker, position size, mid-price." },
      "display-md":  { "$value": { "fontFamily": "{typography.fontFamily.tabular}", "fontSize": "{typography.fontSize.30}", "fontWeight": "{typography.fontWeight.semibold}", "lineHeight": "1.15", "letterSpacing": "-0.015em" }, "$type": "typography" },
      "display-lg":  { "$value": { "fontFamily": "{typography.fontFamily.tabular}", "fontSize": "{typography.fontSize.36}", "fontWeight": "{typography.fontWeight.bold}", "lineHeight": "1.1", "letterSpacing": "-0.02em" }, "$type": "typography", "$description": "Hero number — equity total, big PnL." },
      "code":        { "$value": { "fontFamily": "{typography.fontFamily.mono}", "fontSize": "{typography.fontSize.13}", "fontWeight": "{typography.fontWeight.regular}", "lineHeight": "1.55" }, "$type": "typography" }
    }
  },

  "space": {
    "$description": "4px base grid (Linear convention). Use named scales rather than raw values.",
    "0":   { "$value": "0px",   "$type": "dimension" },
    "px":  { "$value": "1px",   "$type": "dimension" },
    "0_5": { "$value": "2px",   "$type": "dimension" },
    "1":   { "$value": "4px",   "$type": "dimension" },
    "1_5": { "$value": "6px",   "$type": "dimension" },
    "2":   { "$value": "8px",   "$type": "dimension" },
    "3":   { "$value": "12px",  "$type": "dimension" },
    "4":   { "$value": "16px",  "$type": "dimension" },
    "5":   { "$value": "20px",  "$type": "dimension" },
    "6":   { "$value": "24px",  "$type": "dimension" },
    "8":   { "$value": "32px",  "$type": "dimension" },
    "10":  { "$value": "40px",  "$type": "dimension" },
    "12":  { "$value": "48px",  "$type": "dimension" },
    "16":  { "$value": "64px",  "$type": "dimension" },
    "20":  { "$value": "80px",  "$type": "dimension" },
    "24":  { "$value": "96px",  "$type": "dimension" }
  },

  "radius": {
    "none": { "$value": "0px",  "$type": "dimension" },
    "xs":   { "$value": "2px",  "$type": "dimension" },
    "sm":   { "$value": "4px",  "$type": "dimension" },
    "md":   { "$value": "6px",  "$type": "dimension", "$description": "Default for cards, panels, controls." },
    "lg":   { "$value": "8px",  "$type": "dimension" },
    "xl":   { "$value": "12px", "$type": "dimension" },
    "full": { "$value": "9999px","$type": "dimension" }
  },

  "border": {
    "thin":   { "$value": "1px solid {color.neutral.800}", "$type": "border" },
    "subtle": { "$value": "1px solid {color.neutral.700}", "$type": "border" },
    "strong": { "$value": "1px solid {color.neutral.500}", "$type": "border" },
    "focus":  { "$value": "2px solid {color.accent.500}",  "$type": "border" }
  },

  "shadow": {
    "$description": "Shadows are nearly invisible in dark mode — they exist for elevation hints, not drama. Each is a layered tuple: contact + ambient.",
    "none":  { "$value": "none", "$type": "shadow" },
    "sm":    { "$value": "0 1px 2px 0 rgba(0,0,0,0.4)", "$type": "shadow" },
    "md":    { "$value": "0 2px 4px -1px rgba(0,0,0,0.4), 0 4px 8px -2px rgba(0,0,0,0.3)", "$type": "shadow" },
    "lg":    { "$value": "0 8px 16px -4px rgba(0,0,0,0.5), 0 16px 32px -8px rgba(0,0,0,0.35)", "$type": "shadow" },
    "popover": { "$value": "0 4px 8px -2px rgba(0,0,0,0.6), 0 12px 24px -6px rgba(0,0,0,0.45)", "$type": "shadow" }
  },

  "motion": {
    "$description": "Motion budgets per mode (see 01-design-philosophy.md §2). HOT mode uses only the sub-200ms tokens; COOL adds 220ms ease-out; CALM is mostly motionless.",
    "duration": {
      "instant":  { "$value": "0ms",   "$type": "duration" },
      "tick":     { "$value": "120ms", "$type": "duration", "$description": "Price-tick flash; never longer." },
      "snap":     { "$value": "180ms", "$type": "duration", "$description": "HOT mode default." },
      "ease":     { "$value": "220ms", "$type": "duration", "$description": "COOL mode default." },
      "slow":     { "$value": "320ms", "$type": "duration", "$description": "CALM page transitions." }
    },
    "easing": {
      "linear":     { "$value": "linear",                        "$type": "cubicBezier" },
      "ease-out":   { "$value": "cubic-bezier(0.16, 1, 0.3, 1)", "$type": "cubicBezier" },
      "ease-in-out":{ "$value": "cubic-bezier(0.65, 0, 0.35, 1)","$type": "cubicBezier" }
    }
  },

  "z": {
    "base":     { "$value": 0,    "$type": "number" },
    "rise":     { "$value": 10,   "$type": "number" },
    "drawer":   { "$value": 20,   "$type": "number" },
    "popover":  { "$value": 40,   "$type": "number" },
    "modal":    { "$value": 50,   "$type": "number" },
    "toast":    { "$value": 60,   "$type": "number" },
    "kill-overlay": { "$value": 100, "$type": "number", "$description": "The kill-switch armed overlay sits above everything except the kill-switch UI itself." }
  },

  "semantic": {
    "$description": "Mode-scoped semantic aliases. Components reference these, not raw color tokens. To re-skin Praxis, override only this section.",

    "hot": {
      "background": {
        "canvas":    { "$value": "{color.neutral.950}", "$type": "color" },
        "panel":     { "$value": "{color.neutral.900}", "$type": "color" },
        "raised":    { "$value": "{color.neutral.800}", "$type": "color" },
        "row-hover": { "$value": "{color.neutral.800}", "$type": "color" }
      },
      "text": {
        "primary":   { "$value": "{color.neutral.50}",  "$type": "color" },
        "secondary": { "$value": "{color.neutral.300}", "$type": "color" },
        "muted":     { "$value": "{color.neutral.400}", "$type": "color" },
        "disabled":  { "$value": "{color.neutral.600}", "$type": "color" }
      },
      "border": {
        "subtle":    { "$value": "{color.neutral.800}", "$type": "color" },
        "strong":    { "$value": "{color.neutral.700}", "$type": "color" }
      }
    },

    "cool": {
      "background": {
        "canvas":    { "$value": "{color.neutral.950}", "$type": "color" },
        "panel":     { "$value": "{color.neutral.900}", "$type": "color" },
        "raised":    { "$value": "{color.neutral.800}", "$type": "color" }
      },
      "text": {
        "primary":   { "$value": "{color.neutral.50}",  "$type": "color" },
        "secondary": { "$value": "{color.neutral.200}", "$type": "color" },
        "muted":     { "$value": "{color.neutral.400}", "$type": "color" }
      }
    },

    "calm": {
      "background": {
        "canvas":    { "$value": "{color.neutral.900}", "$type": "color", "$description": "Calm mode is slightly less black than hot — invites contemplation." },
        "panel":     { "$value": "{color.neutral.800}", "$type": "color" },
        "raised":    { "$value": "{color.neutral.700}", "$type": "color" }
      },
      "text": {
        "primary":   { "$value": "{color.neutral.50}",  "$type": "color" },
        "secondary": { "$value": "{color.neutral.200}", "$type": "color" },
        "muted":     { "$value": "{color.neutral.400}", "$type": "color" }
      }
    }
  }
}
