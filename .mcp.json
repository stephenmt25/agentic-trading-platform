{
  "mcpServers": {
    "stitch": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@_davideast/stitch-mcp", "proxy"],
      "env": {
        "STITCH_API_KEY": "REPLACE_WITH_NEW_KEY"
      }
    },
    "blender": {
      "command": "uvx",
      "args": ["blender-mcp"],
      "env": {
        "DISABLE_TELEMETRY": "true"
      }
    },
    "remotion": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@remotion/mcp@latest"]
    }
  }
}
